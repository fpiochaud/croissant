{
  "name": "croissant-angular",
  "version": "2.0.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test --watch=false",
    "test:e2e": "npm run e2e",
    "test:all": "npm run test:unit && npm run test:e2e",
    "e2e:kill": "fuser -k 8080/tcp 9099/tcp 4201/tcp 2>/dev/null || true",
    "e2e": "npm run e2e:kill && playwright test",
    "e2e:fast": "npm run e2e:kill && ng build --configuration e2e && USE_STATIC_SERVE=true playwright test",
    "e2e:ui": "npm run e2e:kill && playwright test --ui"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "firebase": "^12.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@playwright/test": "^1.60.0",
    "firebase-admin": "^14.2.0",
    "firebase-tools": "^15.24.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "serve": "^14.2.6",
    "typescript": "~6.0.0",
    "vitest": "^4.1.9"
  },
  "volta": {
    "node": "24.18.0",
    "npm": "11.18.0"
  }
}
