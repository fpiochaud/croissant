{
  "name": "croissant-angular",
  "version": "1.9.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e:kill": "fuser -k 8080/tcp 9099/tcp 4201/tcp 2>/dev/null || true",
    "e2e": "npm run e2e:kill && playwright test",
    "e2e:fast": "npm run e2e:kill && ng build --configuration e2e && USE_STATIC_SERVE=true playwright test",
    "e2e:ui": "npm run e2e:kill && playwright test --ui"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "firebase": "^12.10.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.58.2",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^13.35.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
