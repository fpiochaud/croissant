rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Équipes ────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read, write: if isAuthenticated();

      match /persons/{personId} {
        allow read, write: if isAuthenticated();
      }
      match /history/{entryId} {
        allow read, write: if isAuthenticated();
      }
      match /notifications/{notifId} {
        allow read, write: if isAuthenticated();
      }
      match /tokens/{tokenId} {
        allow read: if false;         // Uniquement GitHub Actions (Admin SDK)
        allow write: if isAuthenticated();
      }
    }

    // ── Profils utilisateurs ───────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ── Suppressions en attente ────────────────────────────────
    // Lecture : l'utilisateur peut vérifier s'il est bloqué (par son email encodé)
    // Écriture : admin uniquement
    match /pendingDeletions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
